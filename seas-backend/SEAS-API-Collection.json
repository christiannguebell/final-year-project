            "body": {
              "mode": "raw",
              "raw": "{\n    \"sessionId\": \"{{examSessionId}}\",\n    \"centerId\": \"{{examCenterId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Assignment",
          "request": {
