<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Verification Code - SEAS Security</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "secondary": "#046d40",
                        "surface-container": "#eceef0",
                        "surface": "#f8f9fb",
                        "on-background": "#191c1e",
                        "on-primary": "#ffffff",
                        "primary": "#00193c",
                        "surface-container-low": "#f2f4f6",
                        "surface-container-lowest": "#ffffff",
                        "primary-container": "#002d62",
                        "on-surface": "#191c1e",
                        "outline-variant": "#c4c6d1",
                        "error": "#ba1a1a"
                    },
                    fontFamily: {
                        "headline": ["Manrope", "sans-serif"],
                        "body": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
</style>
</head>
<body class="bg-surface font-body text-on-surface antialiased p-4 md:p-8">
<!-- Email Container -->
<div class="max-w-[600px] mx-auto overflow-hidden">
<!-- Header: Consistent with TopNavBar rules -->
<header class="bg-[#f8f9fb] px-8 py-6 flex justify-between items-center w-full sticky top-0">
<div class="flex items-center gap-3">
<div class="w-10 h-10 bg-primary flex items-center justify-center rounded-lg">
<span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">engineering</span>
</div>
<div class="flex flex-col">
<span class="text-xl font-['Manrope'] font-bold tracking-tighter text-[#00193c]">SEAS Portal</span>
<span class="text-[10px] uppercase tracking-widest text-secondary font-bold">Engineering Excellence</span>
</div>
</div>
</header>
<!-- Main Body -->
<main class="bg-surface-container-low p-1">
<div class="bg-surface-container-lowest p-8 md:p-12 rounded-xl shadow-[0px_8px_24px_rgba(25,28,30,0.06)]">
<!-- Headline -->
<div class="mb-8">
<h1 class="font-headline text-3xl font-extrabold text-primary tracking-tight mb-2">Verification Code</h1>
<div class="h-1 w-12 bg-secondary rounded-full"></div>
</div>
<p class="text-on-surface text-lg mb-8 leading-relaxed">
    Hi <strong>{{name}}</strong>,<br><br>
    A request was made to access your <span class="font-bold">SEAS Security</span> account. Use the following code to complete your verification process.
</p>
<!-- OTP Display: Prominent Box -->
<div class="bg-surface-container-low rounded-xl p-10 text-center mb-8">
<div class="flex justify-center gap-3 md:gap-4">
    <div class="flex items-center justify-center px-12 py-4 bg-white border-b-2 border-primary text-4xl font-headline font-bold text-primary tracking-[0.5em]">{{otp}}</div>
</div>
</div>
<!-- Security Notice -->
<div class="flex items-start gap-4 p-4 rounded-lg bg-error-container/20 mb-8 border-l-4 border-error">
<span class="material-symbols-outlined text-error mt-1">timer</span>
<div>
<p class="font-bold text-on-surface">Security Notice</p>
<p class="text-sm text-on-surface-variant">This verification code will expire in <span class="font-bold text-error">15 minutes</span>. If you did not request this code, please secure your account immediately or contact support.</p>
</div>
</div>
<!-- Action Anchor -->
<div class="mb-12">
<a class="inline-flex items-center justify-center px-8 py-3 bg-primary text-on-primary font-bold rounded-md hover:bg-primary-container transition-colors gap-2" href="{{resetUrl}}">
<span>Go to Portal</span>
<span class="material-symbols-outlined text-sm">open_in_new</span>
</a>
</div>
<!-- Technical Footer -->
<div class="pt-8 border-t border-outline-variant/30 text-sm text-on-surface-variant">
<p class="mb-2">Reference ID: <span class="font-mono">SEAS-TX-VERIFY</span></p>
</div>
</div>
</main>
<!-- Institutional Footer -->
<footer class="bg-primary text-white p-8 mt-1">
<div class="grid grid-cols-1 gap-8 mb-8">
<div>
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">verified_user</span>
<span class="font-headline font-bold tracking-tight">SEAS Security</span>
</div>
<p class="text-outline-variant text-xs leading-relaxed max-w-xs">
    Committed to engineering excellence and the highest standards of academic integrity and digital security.
</p>
</div>
</div>
<div class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-white/10 gap-4">
<span class="text-[10px] text-white/40 uppercase tracking-tighter">© 2024 Engineering Excellence Academic Institution</span>
</div>
</footer>
</div>
</body></html>
