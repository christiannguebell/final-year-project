<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment Summary - {{applicationId}}</title>
  <style>
    body { font-family: Helvetica, Arial, sans-serif; margin: 0; padding: 40px; color: #333; }
    .header { text-align: center; margin-bottom: 32px; border-bottom: 2px solid #2563eb; padding-bottom: 16px; }
    .header h1 { margin: 0; color: #1e3a8a; font-size: 26px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 16px; }
    th, td { border: 1px solid #e2e8f0; padding: 8px 10px; text-align: left; }
    th { background: #f8fafc; }
    .totals { margin-top: 24px; font-size: 14px; }
    .totals div { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .balance { font-size: 20px; font-weight: bold; color: #1e3a8a; margin-top: 12px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>SEAS Payment Summary</h1>
    <p>{{user.firstName}} {{user.lastName}} · Ref {{applicationId}}</p>
    <p>{{program.name}}</p>
  </div>

  <table>
    <thead>
      <tr><th>Date</th><th>Amount</th><th>Method</th><th>Status</th></tr>
    </thead>
    <tbody>
      {{#each payments}}
      <tr><td>{{date}}</td><td>FCFA {{amount}}</td><td>{{method}}</td><td>{{status}}</td></tr>
      {{/each}}
    </tbody>
  </table>

  <div class="totals">
    <div><span>Total Invoiced</span><span>FCFA {{totalInvoiced}}</span></div>
    <div><span>Total Paid</span><span>FCFA {{totalPaid}}</span></div>
    <div class="balance"><span>Balance Due</span><span>FCFA {{balanceDue}}</span></div>
  </div>

  <p style="font-size: 12px; color: #64748b; margin-top: 24px;">Generated: {{generatedAt}}</p>
</body>
</html>
