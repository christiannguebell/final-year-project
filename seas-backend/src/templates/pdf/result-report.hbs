<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Result Report - {{user.firstName}} {{user.lastName}}</title>
  <style>
    body { font-family: Helvetica, Arial, sans-serif; margin: 0; padding: 40px; color: #333; }
    .header { text-align: center; margin-bottom: 32px; border-bottom: 2px solid #046d40; padding-bottom: 16px; }
    .header h1 { margin: 0; color: #00193c; font-size: 26px; }
    .section { margin-bottom: 24px; }
    .section-title { font-size: 16px; font-weight: bold; color: #00193c; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { border: 1px solid #e2e8f0; padding: 8px 10px; text-align: left; }
    th { background: #f8fafc; }
    .summary { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-size: 14px; }
    .label { font-weight: bold; color: #475569; }
  </style>
</head>
<body>
  <div class="header">
    <h1>SEAS Examination Result Report</h1>
    <p>Official score summary for {{user.firstName}} {{user.lastName}}</p>
  </div>

  <div class="section">
    <div class="section-title">Candidate Information</div>
    <div class="summary">
      <div><span class="label">Program:</span> {{program.name}}</div>
      <div><span class="label">Status:</span> {{status}}</div>
      <div><span class="label">Total Score:</span> {{totalScore}}</div>
      <div><span class="label">Rank:</span> {{rank}}</div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Subject Breakdown</div>
    <table>
      <thead>
        <tr><th>Subject</th><th>Score</th><th>Max</th></tr>
      </thead>
      <tbody>
        {{#each scores}}
        <tr><td>{{subject}}</td><td>{{score}}</td><td>{{maxScore}}</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <p style="font-size: 12px; color: #64748b;">Published: {{publishedAt}}</p>
</body>
</html>
